# Copy to .env and fill in your Supabase project values before building.
# These are baked into the frontend bundle at Docker build time (Vite requirement).

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional: host port when running via docker-compose (default: 8080)
# HOST_PORT=8080
