# Dependencies and build output (rebuilt inside the image)
node_modules/
dist/
.vite/

# Environment files (secrets must not enter the build context)
.env
.env.*
!.env.example

# Supabase backend — not part of the frontend container
supabase/

# Version control and editor metadata
.git/
.gitignore
.vscode/

# Docker files (not needed inside the build context copy)
Dockerfile
docker-compose.yml
.dockerignore

# OS and log artifacts
.DS_Store
Thumbs.db
*.log
npm-debug.log*

# TypeScript incremental cache
tsconfig.tsbuildinfo

# Documentation
README.md
